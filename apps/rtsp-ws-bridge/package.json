{
  "name": "@ad-stream-bridge/rtsp-ws-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "Minimal Express service for the RTSP to WebSocket-FLV bridge.",
  "keywords": [
    "ad-stream-bridge",
    "rtsp",
    "websocket",
    "flv",
    "express",
    "nodejs",
    "typescript"
  ],
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node -e \"console.log('No tests yet for @ad-stream-bridge/rtsp-ws-bridge')\"",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@adui/logger": "workspace:*",
    "express": "^5.2.1",
    "express-ws": "^5.0.2",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@adui/typescript-config": "workspace:*",
    "@types/express": "^5.0.6",
    "@types/express-ws": "^3.0.6",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "rimraf": "^6.1.3",
    "tsx": "^4.21.0"
  }
}
