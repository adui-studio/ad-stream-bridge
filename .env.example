# ------------------------------------------------------------------------------
# ad-stream-bridge / rtsp-ws-bridge
# Example environment configuration
#
# Copy this file to `.env` for local development and adjust values as needed.
# ------------------------------------------------------------------------------

# ------------------------------------------------------------------------------
# App runtime
# ------------------------------------------------------------------------------

# Node.js runtime environment
# Common values: development | test | production
NODE_ENV=development

# HTTP/WebSocket server bind host
HOST=0.0.0.0

# HTTP/WebSocket server listen port
PORT=3000

# Application log level
# Suggested values: debug | info | warn | error
LOG_LEVEL=info

# ------------------------------------------------------------------------------
# RTSP source resolution
# ------------------------------------------------------------------------------

# Optional RTSP URL template used when the client connects to:
#   ws://host:port/live/:id
# and does NOT provide ?url=...
#
# Example:
#   RTSP_URL_TEMPLATE=rtsp://your-rtsp-host/live/{id}
#
# Then:
#   /live/camera-01
# will resolve to:
#   rtsp://your-rtsp-host/live/camera-01
#
# Leave empty if you prefer to always pass:
#   ?url=rtsp://...
RTSP_URL_TEMPLATE=rtsp://your-rtsp-host/live/{id}

# ------------------------------------------------------------------------------
# FFmpeg
# ------------------------------------------------------------------------------

# FFmpeg executable path.
# If set to `ffmpeg`, the service will use the system PATH.
# On Windows you can also set an absolute path, for example:
#   FFMPEG_PATH=C:\ffmpeg\bin\ffmpeg.exe
FFMPEG_PATH=ffmpeg

# ------------------------------------------------------------------------------
# Stream recovery / lifecycle
# ------------------------------------------------------------------------------

# If FFmpeg produces no stdout data for longer than this duration (milliseconds),
# the stream manager will treat the session as stalled and trigger a restart.
STREAM_IDLE_TIMEOUT_MS=15000

# Sweep interval in milliseconds for checking active sessions and detecting idle
# sessions with no recent output data.
STREAM_SWEEP_INTERVAL_MS=10000

# Delay in milliseconds before restarting FFmpeg after an unexpected exit.
# This applies only to non-manual exits.
STREAM_RESTART_DELAY_MS=3000

# Maximum number of automatic restart attempts after unexpected FFmpeg exits.
# 0 means "do not retry".
STREAM_MAX_RESTARTS=5
