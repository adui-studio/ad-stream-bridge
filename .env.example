NODE_ENV=development
PORT=3000
HOST=0.0.0.0

LOG_LEVEL=info

RTSP_URL_TEMPLATE=rtsp://your-rtsp-host/live/{id}

# ffmpeg binary path, fallback to system PATH if empty
FFMPEG_PATH=ffmpeg

# when ffmpeg outputs no data for too long, force recycle session
STREAM_IDLE_TIMEOUT_MS=15000

# delay before restarting ffmpeg session after unexpected exit
STREAM_RESTART_DELAY_MS=3000

# max restart attempts in a rolling window, 0 means unlimited
STREAM_MAX_RESTARTS=0

# session sweep interval
STREAM_SWEEP_INTERVAL_MS=10000
